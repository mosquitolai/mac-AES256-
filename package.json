{
  "name": "mola-vault",
  "version": "1.1.0",
  "description": "Mola Vault — Minimal AES & ZIP encryption for macOS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac"
  },
  "build": {
    "appId": "com.molavault.app",
    "productName": "Mola Vault",
    "win": {
   
      "target": "nsis",
      "icon": "assets/logo_01.ico"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "target": [{ "target": "dmg", "arch": ["arm64","x64"] }],
      "icon": "assets/logo.png",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "files": ["main.js","preload.js","crypto/**","renderer/**","assets/**"]
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  }
}
